# Environment Settings
ENV=development
PROJECT_NAME="Intelligent Candidate Discovery"
API_V1_STR="/api/v1"

# Database Connection (Optional, falls back to CSV if empty)
DATABASE_URL=
# Example: postgresql://postgres:postgres@localhost:5432/candidate_discovery

# Data Directory (Absolute or relative path to data folder)
DATA_DIR=../data
CHALLENGE_DATA_DIR=../../[PUB] India_runs_data_and_ai_challenge/India_runs_data_and_ai_challenge

# ML Settings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
FAISS_INDEX_PATH=../data/embeddings/faiss_index.bin
RANKER_MODEL_PATH=../data/processed/xgboost_ranker.json
